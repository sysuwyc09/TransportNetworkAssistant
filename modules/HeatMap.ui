QPushButton {
    background-color: rgba(28, 33, 44, 255);
    color: #44cc88;
    border: 1px solid #44cc88;
    border-radius: 10px;
    padding: 5px 10px;
}

QPushButton:hover {
    background-color: rgba(40, 45, 56, 255);
}

QPushButton:pressed {
    background-color: rgba(20, 25, 36, 255);
}

QLineEdit {
    background-color: rgba(28, 33, 44, 255);
    color: #44cc88;
    border: 1px solid #44cc88;
    border-radius: 5px;
    padding: 5px 10px;
}
QSlider::groove:horizontal {
                height: 6px;
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
                                           stop:0 rgba(60, 70, 85, 255), 
                                           stop:1 rgba(80, 90, 105, 255));
                border-radius: 3px;
                margin: 0 10px;
            }
            QSlider::groove:vertical {
                width: 6px;
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
                                           stop:0 rgba(60, 70, 85, 255), 
                                           stop:1 rgba(80, 90, 105, 255));
                border-radius: 3px;
                margin: 10px 0;
            }

            /* 滑块手柄部分 */
            QSlider::handle:horizontal {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
                                           stop:0 rgba(100, 115, 135, 255), 
                                           stop:1 rgba(80, 95, 115, 255));
                border: 1px solid rgba(120, 135, 155, 255);
                width: 20px;
                height: 20px;
                border-radius: 10px;
                margin: -7px 0; /* 超出轨道上下方 */
            }
            QSlider::handle:vertical {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
                                           stop:0 rgba(100, 115, 135, 255), 
                                           stop:1 rgba(80, 95, 115, 255));
                border: 1px solid rgba(120, 135, 155, 255);
                width: 20px;
                height: 20px;
                border-radius: 10px;
                margin: 0 -7px; /* 超出轨道左右方 */
            }

            /* 手柄悬停状态 */
            QSlider::handle:horizontal:hover, QSlider::handle:vertical:hover {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
                                           stop:0 rgba(120, 135, 155, 255), 
                                           stop:1 rgba(100, 115, 135, 255));
                border-color: rgba(140, 155, 175, 255);
            }

            /* 手柄按下状态 */
            QSlider::handle:horizontal:pressed, QSlider::handle:vertical:pressed {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
                                           stop:0 rgba(80, 95, 115, 255), 
                                           stop:1 rgba(60, 75, 95, 255));
                border-color: rgba(100, 115, 135, 255);
            }

            /* 已滑动部分的填充（可选） */
            QSlider::sub-page:horizontal {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
                                           stop:0 rgba(90, 105, 125, 255), 
                                           stop:1 rgba(110, 125, 145, 255));
                border-radius: 3px;
            }
            QSlider::sub-page:vertical {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
                                           stop:0 rgba(90, 105, 125, 255), 
                                           stop:1 rgba(110, 125, 145, 255));
                border-radius: 3px;
            }
</string>
